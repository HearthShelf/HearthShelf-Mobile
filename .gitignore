# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Firebase / FCM. google-services.json holds a public app API key (safe-ish) but
# is kept local; the service-account *private* key is a real secret - never commit.
google-services.json
google-services*.json
*-firebase-adminsdk-*.json
service-account*.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# fastlane generated / transient artifacts (signing assets are covered by the
# *.p12 / *.mobileprovision rules above)
fastlane/report.xml
fastlane/README.md
fastlane/test_output/
ios/build/

# local-only agent notes
CLAUDE.local.md

# per-machine agent config: local MCP settings, a dev-server launch config, and a
# PID lockfile. Machine state, not project state.
.claude/

.env.local

.env.local
