# HearthShelf Mobile - public build-time config.
#
# Copy to `.env` (gitignored) and fill in. EVERYTHING here is PUBLIC by design:
# the Clerk publishable key and Google *client IDs* ship in the app bundle. The
# Google client *secret* is NEVER here - it lives only in the Clerk dashboard.
#
# These are read by src/lib/config.ts (process.env first, then app.config extra).
# Metro inlines EXPO_PUBLIC_* at build time, so a rebuild is required after edits.

# Control plane (server pairing + grants). Prod default if unset.
EXPO_PUBLIC_CONTROL_PLANE_URL=https://api.hearthshelf.com

# Clerk publishable key. Use a pk_test_... for a dev Clerk instance, pk_live_...
# for prod. Defaults to the prod key if unset.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsuaGVhcnRoc2hlbGYuY29tJA

# Native Google sign-in (Android Credential Manager / iOS reversed-client-ID).
# These are PUBLIC OAuth client IDs and are now baked as committed defaults in
# app.config.js, so NATIVE_GOOGLE_ENABLED is on in every build (local + CI) with
# no config needed. Set these ONLY to override - e.g. to point a dev build at a
# different Clerk instance's Google credentials. See AUTH_SETUP.md.
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_CLERK_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID=
# iOS only - the reversed iOS client ID, e.g. com.googleusercontent.apps.123-abc
EXPO_PUBLIC_CLERK_GOOGLE_IOS_URL_SCHEME=

# --- Push notifications (release alerts) ---
# The Expo/EAS project id that mints push tokens. Get it with `eas init` (writes
# it to eas.json + app config) or copy it from expo.dev > your project. Leave
# blank to keep push OFF - the in-app Home countdown still works either way.
# See docs/PUSH_SETUP.md.
EXPO_PUBLIC_EAS_PROJECT_ID=
# Android push also needs FCM: point this at a Firebase google-services.json.
# NOT EXPO_PUBLIC_ (it's a build-time file path, not bundled). See docs/PUSH_SETUP.md.
# GOOGLE_SERVICES_JSON=./google-services.json

# --- PostHog analytics ---
# Public project token (safe to commit; ships in the app bundle like Sentry DSN).
# Leave blank to disable analytics without breaking the build.
EXPO_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_project_token_here
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Android RELEASE signing (LOCAL TEST BUILDS ONLY) ---
# UNLIKE everything above, these are NOT EXPO_PUBLIC_ and are NOT baked into the
# app bundle - they are build-time signing inputs, and they ARE secret. Real
# releases are built by GitHub Actions from repo secrets (see
# .github/workflows/build-android-release.yml); set these only when you want to
# produce a signed release build on your own machine to test the pipeline.
# Leave blank/unset for normal debug dev - the signing plugin stays inert unless
# HEARTHSHELF_RELEASE_SIGNING=1. See RELEASE.md.
#
# HEARTHSHELF_RELEASE_SIGNING=1
# HEARTHSHELF_RELEASE_KEYSTORE_PATH=C:\path\to\upload.jks
# HEARTHSHELF_RELEASE_KEYSTORE_PASSWORD=
# HEARTHSHELF_RELEASE_KEY_ALIAS=upload
# HEARTHSHELF_RELEASE_KEY_PASSWORD=
