# fastlane Fastfile - HearthShelf Mobile iOS release to TestFlight.
#
# Runs on a GitHub-hosted macOS runner (NOT EAS Build - this escapes the EAS
# free-tier 15 builds/month cap). Signing uses an uploaded Apple Distribution
# certificate + App Store provisioning profile; App Store Connect auth uses an
# API key (.p8), so there is NO interactive Apple login and the account's
# YubiKey-only 2FA is never hit.
#
# The Expo project is regenerated by `expo prebuild` before this runs, so the
# Xcode project/workspace live at ios/HearthShelf.xcodeproj / .xcworkspace.
#
# Env expected (set by the workflow from GitHub secrets):
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_P8_BASE64  - App Store Connect API key
#   IOS_DIST_P12_BASE64, IOS_DIST_P12_PASSWORD    - distribution cert + key
#   IOS_PROVISION_PROFILE_BASE64                  - App Store provisioning profile
#   KEYCHAIN_PASSWORD                             - throwaway temp keychain pass
#   PROVISIONING_PROFILE_NAME                     - e.g. "HearthShelf App Store"

default_platform(:ios)

WORKSPACE = 'ios/HearthShelf.xcworkspace'
SCHEME = 'HearthShelf'
BUNDLE_ID = 'com.hearthshelf.mobile'

platform :ios do
  desc 'Build the signed IPA and upload it to TestFlight'
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch('ASC_KEY_ID'),
      issuer_id: ENV.fetch('ASC_ISSUER_ID'),
      key_content: ENV.fetch('ASC_KEY_P8_BASE64'),
      is_key_content_base64: true,
      in_house: false,
    )

    # Import the distribution cert into a throwaway keychain for this run.
    keychain_name = 'hearthshelf-ci.keychain'
    keychain_password = ENV.fetch('KEYCHAIN_PASSWORD', 'ci-temp-pass')
    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
    )
    import_certificate(
      certificate_path: 'fastlane/dist.p12',
      certificate_password: ENV.fetch('IOS_DIST_P12_PASSWORD'),
      keychain_name: keychain_name,
      keychain_password: keychain_password,
    )

    # Install the App Store provisioning profile so Xcode can find it by name.
    profile_name = ENV.fetch('PROVISIONING_PROFILE_NAME', 'HearthShelf App Store')
    install_provisioning_profile(path: 'fastlane/profile.mobileprovision')

    # Force manual signing with our uploaded cert + profile (prebuild leaves the
    # project on automatic signing, which fails headless on CI).
    update_code_signing_settings(
      use_automatic_signing: false,
      path: 'ios/HearthShelf.xcodeproj',
      team_id: 'HCU6KVPTDC',
      code_sign_identity: 'Apple Distribution',
      bundle_identifier: BUNDLE_ID,
      profile_name: profile_name,
    )

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: 'Release',
      clean: true,
      export_method: 'app-store',
      output_directory: 'ios/build',
      output_name: 'HearthShelf.ipa',
      export_options: {
        provisioningProfiles: {
          BUNDLE_ID => profile_name,
        },
        signingStyle: 'manual',
      },
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: 'ios/build/HearthShelf.ipa',
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end
end
